// ============================================================
// SUSHI IN SUSHI — Database Schema (DBML format)
// For use with dbdiagram.io
// 36 tables, all relationships
// ============================================================

// ========================
// CORE
// ========================

Table roles {
  id serial [pk]
  name varchar(50) [unique, not null, note: 'admin, kitchen, waiter, customer']
  description text
  created_at timestamptz [default: `now()`]
}

Table staff {
  id uuid [pk]
  email varchar(255) [unique, not null]
  name varchar(255) [not null]
  auth_user_id uuid [unique, note: 'FK -> auth.users(id) ON DELETE SET NULL']
  role_id integer [not null, ref: > roles.id]
  location varchar(50) [note: 'circunvalacao, boavista']
  phone varchar(20)
  is_active boolean [default: true]
  last_login timestamptz
  created_at timestamptz [default: `now()`]
}

Table kitchen_zones {
  id uuid [pk]
  name varchar(100) [not null]
  slug varchar(50) [unique, not null]
  color varchar(7) [default: '#6B7280']
  sort_order integer [default: 0]
  is_active boolean [default: true]
  created_at timestamptz [default: `now()`]
  updated_at timestamptz [default: `now()`]
}

Table categories {
  id uuid [pk]
  name varchar(100) [not null]
  slug varchar(50) [unique, not null]
  sort_order integer [default: 0]
  icon varchar(10)
  created_at timestamptz [default: `now()`]
  updated_at timestamptz [default: `now()`]
  vendus_id varchar(50) [unique]
  vendus_synced_at timestamptz
  zone_id uuid [ref: > kitchen_zones.id]
}

Table locations {
  id uuid [pk]
  name varchar(100) [not null]
  slug varchar(50) [unique, not null]
  address text
  phone varchar(20)
  is_active boolean [default: true]
  created_at timestamptz [default: `now()`]
  updated_at timestamptz [default: `now()`]
  vendus_store_id varchar(50)
  vendus_register_id varchar(50)
  vendus_enabled boolean [default: false]
}

Table products {
  id uuid [pk]
  name varchar(255) [not null]
  description text
  price decimal(10,2) [not null]
  category_id uuid [not null, ref: > categories.id]
  image_url text
  is_available boolean [default: true]
  is_rodizio boolean [default: false]
  sort_order integer [default: 0]
  created_at timestamptz [default: `now()`]
  updated_at timestamptz [default: `now()`]
  image_urls text[]
  quantity integer [not null, default: 1]
  vendus_id varchar(50)
  vendus_reference varchar(100)
  vendus_tax_id varchar(50)
  vendus_synced_at timestamptz
  vendus_sync_status varchar(20) [default: 'pending', note: 'pending, synced, error, not_applicable']
  vendus_ids jsonb [default: '{}']
  location_id uuid [ref: > locations.id]
  service_modes text[] [default: '{}']
  service_prices jsonb [default: '{}']
}

Table tables {
  id uuid [pk]
  number integer [not null]
  name varchar(100) [not null]
  location varchar(50) [not null]
  is_active boolean [default: true]
  created_at timestamptz [default: `now()`]
  updated_at timestamptz [default: `now()`]
  status varchar(20) [default: 'available', note: 'available, reserved, occupied, inactive']
  status_note text
  current_session_id uuid
  current_reservation_id uuid
  vendus_table_id varchar(50)
  vendus_room_id varchar(50)
  vendus_synced_at timestamptz
}

// ========================
// SESSIONS & ORDERS
// ========================

Table sessions {
  id uuid [pk]
  table_id uuid [not null, ref: > tables.id]
  started_at timestamptz [default: `now()`]
  closed_at timestamptz
  is_rodizio boolean [default: false]
  num_people integer [default: 1]
  status varchar(20) [default: 'active', note: 'active, pending_payment, paid, closed']
  notes text
  total_amount decimal(10,2) [default: 0]
  created_at timestamptz [default: `now()`]
  updated_at timestamptz [default: `now()`]
  first_order_at timestamptz
  last_order_at timestamptz
  bill_requested_at timestamptz
  time_to_first_order integer [note: 'seconds']
  total_duration integer [note: 'seconds']
  time_ordering integer [note: 'seconds']
  ordering_mode varchar(20) [default: 'client', note: 'client, waiter_only']
  customer_nif varchar(20)
}

Table customers {
  id uuid [pk]
  email varchar(255) [unique, not null]
  name varchar(255) [not null]
  phone varchar(20)
  birth_date date
  preferred_location varchar(50)
  marketing_consent boolean [default: false]
  points integer [default: 0]
  total_spent decimal(10,2) [default: 0]
  visit_count integer [default: 0]
  is_active boolean [default: true]
  created_at timestamptz [default: `now()`]
  updated_at timestamptz [default: `now()`]
  email_verified boolean [not null, default: false]
  phone_verified boolean [not null, default: false]
}

Table session_customers {
  id uuid [pk]
  session_id uuid [not null, ref: > sessions.id]
  display_name varchar(100) [not null]
  full_name varchar(200)
  email varchar(255)
  phone varchar(50)
  birth_date date
  marketing_consent boolean [default: false]
  preferred_contact varchar(20) [default: 'email', note: 'email, phone, none']
  customer_id uuid [ref: > customers.id]
  is_session_host boolean [default: false]
  created_at timestamptz [default: `now()`]
  updated_at timestamptz [default: `now()`]
  device_id uuid
  tier smallint [not null, default: 1, note: '1=Session, 2=Basic, 3=Full, 4=Delivery']
  email_verified boolean [not null, default: false]
  phone_verified boolean [not null, default: false]
  verification_token text
  verification_expires_at timestamptz
  verification_type varchar(20) [note: 'email, phone']
}

Table orders {
  id uuid [pk]
  session_id uuid [not null, ref: > sessions.id]
  product_id uuid [not null, ref: > products.id]
  quantity integer [default: 1]
  unit_price decimal(10,2) [not null]
  notes text
  status varchar(20) [default: 'pending', note: 'pending, preparing, ready, delivered, cancelled']
  created_at timestamptz [default: `now()`]
  updated_at timestamptz [default: `now()`]
  session_customer_id uuid [ref: > session_customers.id]
  prepared_by uuid [ref: > staff.id]
  preparing_started_at timestamptz
  ready_at timestamptz
  delivered_at timestamptz
}

// ========================
// WAITER MANAGEMENT
// ========================

Table waiter_tables {
  id serial [pk]
  staff_id uuid [not null, ref: > staff.id]
  table_id uuid [not null, ref: > tables.id]
  assigned_at timestamptz [default: `now()`]

  indexes {
    (staff_id, table_id) [unique]
  }
}

Table waiter_calls {
  id uuid [pk]
  table_id uuid [not null, ref: > tables.id]
  session_id uuid [ref: > sessions.id]
  call_type varchar(50) [default: 'assistance', note: 'assistance, bill, order, other']
  message text
  status varchar(20) [default: 'pending', note: 'pending, acknowledged, completed, cancelled']
  acknowledged_by uuid [ref: > staff.id]
  acknowledged_at timestamptz
  completed_at timestamptz
  location varchar(50) [not null]
  created_at timestamptz [default: `now()`]
  updated_at timestamptz [default: `now()`]
  order_id uuid [ref: > orders.id]
  session_customer_id uuid
}

// ========================
// RESERVATIONS
// ========================

Table reservations {
  id uuid [pk]
  first_name varchar(100) [not null]
  last_name varchar(100) [not null]
  email varchar(255) [not null]
  phone varchar(20) [not null]
  reservation_date date [not null]
  reservation_time time [not null]
  party_size integer [not null]
  location varchar(50) [not null]
  table_id uuid [ref: > tables.id]
  is_rodizio boolean [default: true]
  special_requests text
  occasion varchar(50)
  status varchar(20) [default: 'pending', note: 'pending, confirmed, cancelled, completed, no_show']
  confirmed_by uuid [ref: > staff.id]
  confirmed_at timestamptz
  cancelled_at timestamptz
  cancellation_reason text
  session_id uuid [ref: > sessions.id]
  seated_at timestamptz
  marketing_consent boolean [default: false]
  created_at timestamptz [default: `now()`]
  updated_at timestamptz [default: `now()`]
  customer_email_id varchar(255)
  customer_email_sent_at timestamptz
  customer_email_delivered_at timestamptz
  customer_email_opened_at timestamptz
  customer_email_status varchar(50)
  confirmation_email_id varchar(255)
  confirmation_email_sent_at timestamptz
  confirmation_email_delivered_at timestamptz
  confirmation_email_opened_at timestamptz
  confirmation_email_status varchar(50)
  day_before_reminder_id varchar(255)
  day_before_reminder_sent_at timestamptz
  day_before_reminder_delivered_at timestamptz
  day_before_reminder_opened_at timestamptz
  day_before_reminder_status varchar(50)
  same_day_reminder_id varchar(255)
  same_day_reminder_sent_at timestamptz
  same_day_reminder_delivered_at timestamptz
  same_day_reminder_opened_at timestamptz
  same_day_reminder_status varchar(50)
  tables_assigned boolean [default: false]
}

Table reservation_tables {
  id uuid [pk]
  reservation_id uuid [not null, ref: > reservations.id]
  table_id uuid [not null, ref: > tables.id]
  is_primary boolean [not null, default: false]
  assigned_by uuid [ref: > staff.id]
  assigned_at timestamptz [default: `now()`]

  indexes {
    (reservation_id, table_id) [unique]
  }
}

Table reservation_settings {
  id integer [pk, default: 1, note: 'Singleton']
  day_before_reminder_enabled boolean [default: true]
  day_before_reminder_hours integer [default: 24]
  same_day_reminder_enabled boolean [default: true]
  same_day_reminder_hours integer [default: 2]
  rodizio_waste_policy_enabled boolean [default: true]
  rodizio_waste_fee_per_piece decimal(10,2) [default: 2.50]
  updated_at timestamptz [default: `now()`]
  updated_by uuid [ref: > staff.id]
  waiter_alert_minutes integer [default: 60]
}

// ========================
// RESTAURANTS & CONFIG
// ========================

Table restaurants {
  id uuid [pk]
  name varchar(100) [not null]
  slug varchar(50) [unique, not null]
  address text [not null]
  latitude decimal(10,8)
  longitude decimal(11,8)
  max_capacity integer [not null]
  default_people_per_table integer [not null, default: 4]
  auto_table_assignment boolean [not null, default: false]
  auto_reservations boolean [not null, default: false]
  is_active boolean [not null, default: true]
  created_at timestamp [default: `now()`]
  updated_at timestamp [default: `now()`]
  order_cooldown_minutes integer [not null, default: 0]
  show_upgrade_after_order boolean [not null, default: false]
  show_upgrade_at_bill boolean [not null, default: false]
  games_enabled boolean [not null, default: false]
  games_mode varchar(20) [default: 'selection', note: 'selection, random']
  games_prize_type varchar(30) [default: 'none', note: 'none, discount_percentage, free_product, free_dinner']
  games_prize_value text
  games_prize_product_id uuid [ref: > products.id]
  games_min_rounds_for_prize integer [not null, default: 1]
  games_questions_per_round integer [not null, default: 6]
}

// ========================
// STAFF MANAGEMENT
// ========================

Table staff_time_off {
  id serial [pk]
  staff_id uuid [not null, ref: > staff.id]
  start_date date [not null]
  end_date date [not null]
  type varchar(20) [not null, default: 'vacation', note: 'vacation, sick, personal, other']
  reason text
  status varchar(20) [not null, default: 'approved', note: 'pending, approved, rejected']
  approved_by uuid [ref: > staff.id]
  approved_at timestamptz
  created_at timestamptz [default: `now()`]
  updated_at timestamptz [default: `now()`]
}

Table restaurant_closures {
  id serial [pk]
  closure_date date [not null]
  location varchar(50) [note: 'circunvalacao, boavista, null=all']
  reason text
  is_recurring boolean [default: false]
  recurring_day_of_week integer [note: '0=Sun, 6=Sat']
  created_by uuid [ref: > staff.id]
  created_at timestamptz [default: `now()`]
  updated_at timestamptz [default: `now()`]

  indexes {
    (closure_date, location) [unique]
  }
}

// ========================
// ACTIVITY & METRICS
// ========================

Table activity_log {
  id serial [pk]
  staff_id uuid [ref: > staff.id]
  action varchar(100) [not null]
  entity_type varchar(50)
  entity_id varchar(100)
  details jsonb
  ip_address inet
  user_agent text
  created_at timestamptz [default: `now()`]
}

Table table_status_history {
  id serial [pk]
  table_id uuid [not null, ref: > tables.id]
  old_status varchar(20)
  new_status varchar(20)
  changed_by uuid [ref: > staff.id]
  reason text
  reservation_id uuid
  session_id uuid
  created_at timestamptz [default: `now()`]
}

Table daily_metrics {
  id serial [pk]
  date date [not null]
  location varchar(20) [not null]
  total_sessions integer [default: 0]
  rodizio_sessions integer [default: 0]
  carta_sessions integer [default: 0]
  total_covers integer [default: 0]
  avg_time_to_first_order integer
  avg_session_duration integer
  avg_rodizio_duration integer
  avg_carta_duration integer
  total_revenue decimal(10,2) [default: 0]
  avg_ticket decimal(10,2) [default: 0]
  total_reservations integer [default: 0]
  confirmed_reservations integer [default: 0]
  cancelled_reservations integer [default: 0]
  no_shows integer [default: 0]
  walk_ins integer [default: 0]
  created_at timestamptz [default: `now()`]
  updated_at timestamptz [default: `now()`]

  indexes {
    (date, location) [unique]
  }
}

// ========================
// EMAIL TRACKING
// ========================

Table email_events {
  id uuid [pk]
  reservation_id uuid [ref: > reservations.id]
  email_id varchar(255) [not null]
  event_type varchar(50) [not null]
  email_type varchar(50)
  recipient_email varchar(255)
  raw_data jsonb
  event_timestamp timestamptz
  created_at timestamptz [default: `now()`]
}

// ========================
// PRODUCT RATINGS
// ========================

Table product_ratings {
  id uuid [pk]
  session_id uuid [not null, ref: > sessions.id]
  session_customer_id uuid [ref: > session_customers.id]
  product_id uuid [not null, ref: > products.id]
  rating smallint [not null, note: '1-5']
  created_at timestamptz [not null, default: `now()`]
  order_id uuid [ref: > orders.id]

  indexes {
    (session_id, session_customer_id, product_id) [unique]
  }
}

// ========================
// INGREDIENTS
// ========================

Table ingredients {
  id uuid [pk]
  name text [not null, note: 'unique on lower(name)']
  unit text [not null, note: 'g, kg, ml, L, un']
  sort_order integer [not null, default: 0]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
}

Table product_ingredients {
  id uuid [pk]
  product_id uuid [not null, ref: > products.id]
  ingredient_id uuid [not null, ref: > ingredients.id]
  quantity numeric(10,3) [not null]
  created_at timestamptz [not null, default: `now()`]

  indexes {
    (product_id, ingredient_id) [unique]
  }
}

// ========================
// GAMES
// ========================

Table game_questions {
  id uuid [pk]
  game_type varchar(20) [not null, note: 'tinder, quiz, preference']
  question_text text [not null]
  options jsonb
  correct_answer_index smallint
  option_a jsonb
  option_b jsonb
  category varchar(50)
  difficulty smallint [default: 1, note: '1-3']
  points integer [default: 10]
  is_active boolean [default: true]
  restaurant_id uuid [ref: > restaurants.id]
  created_at timestamptz [default: `now()`]
  updated_at timestamptz [default: `now()`]
}

Table game_sessions {
  id uuid [pk]
  session_id uuid [not null, ref: > sessions.id]
  status varchar(20) [default: 'active', note: 'active, completed, abandoned']
  round_number integer [default: 1]
  total_questions integer [default: 6]
  started_at timestamptz [default: `now()`]
  completed_at timestamptz
  created_at timestamptz [default: `now()`]
  game_type varchar(20)
}

Table game_answers {
  id uuid [pk]
  game_session_id uuid [not null, ref: > game_sessions.id]
  session_customer_id uuid [ref: > session_customers.id]
  question_id uuid [ref: > game_questions.id]
  game_type varchar(20) [not null]
  answer jsonb [not null]
  score_earned integer [default: 0]
  answered_at timestamptz [default: `now()`]
  product_id uuid [ref: > products.id]
}

Table game_prizes {
  id uuid [pk]
  session_id uuid [not null, ref: > sessions.id]
  game_session_id uuid [ref: > game_sessions.id]
  session_customer_id uuid [ref: > session_customers.id]
  display_name varchar(100) [not null]
  prize_type varchar(30) [not null, note: 'discount_percentage, free_product, free_dinner']
  prize_value text [not null]
  prize_description text
  total_score integer [default: 0]
  redeemed boolean [default: false]
  redeemed_at timestamptz
  created_at timestamptz [default: `now()`]
}

// ========================
// DEVICE PROFILES
// ========================

Table device_profiles {
  device_id uuid [pk]
  last_display_name varchar(100)
  last_full_name varchar(200)
  last_email varchar(255)
  last_phone varchar(50)
  last_birth_date date
  last_preferred_contact varchar(20) [default: 'email']
  highest_tier smallint [not null, default: 1]
  linked_customer_id uuid [ref: > customers.id]
  visit_count integer [not null, default: 1]
  first_seen_at timestamptz [default: `now()`]
  last_seen_at timestamptz [default: `now()`]
  created_at timestamptz [default: `now()`]
  updated_at timestamptz [default: `now()`]
}

// ========================
// IDENTITY VERIFICATION
// ========================

Table verification_logs {
  id uuid [pk]
  session_customer_id uuid [ref: > session_customers.id]
  customer_id uuid [ref: > customers.id]
  verification_type varchar(20) [not null, note: 'email, phone']
  contact_value text [not null]
  token text [not null]
  expires_at timestamptz [not null]
  status varchar(20) [not null, default: 'sent', note: 'sent, verified, expired, failed']
  verified_at timestamptz
  ip_address inet
  user_agent text
  created_at timestamptz [default: `now()`]
  updated_at timestamptz [default: `now()`]
}

// ========================
// VENDUS POS
// ========================

Table payment_methods {
  id serial [pk]
  name varchar(100) [not null]
  slug varchar(50) [unique, not null]
  vendus_id varchar(50)
  is_active boolean [default: true]
  sort_order integer [default: 0]
  created_at timestamptz [default: `now()`]
}

Table invoices {
  id uuid [pk]
  session_id uuid [ref: > sessions.id]
  location_id uuid [ref: > locations.id]
  vendus_id varchar(50) [unique]
  vendus_document_number varchar(50)
  vendus_document_type varchar(20) [default: 'FR']
  vendus_series varchar(20)
  vendus_hash varchar(255)
  subtotal decimal(10,2) [not null]
  tax_amount decimal(10,2) [not null, default: 0]
  total decimal(10,2) [not null]
  currency varchar(3) [default: 'EUR']
  payment_method_id integer [ref: > payment_methods.id]
  paid_amount decimal(10,2)
  change_amount decimal(10,2) [default: 0]
  customer_nif varchar(20)
  customer_name varchar(255)
  status varchar(20) [default: 'pending', note: 'pending, issued, voided, error']
  voided_at timestamptz
  voided_by uuid [ref: > staff.id]
  void_reason text
  pdf_url text
  pdf_generated_at timestamptz
  issued_by uuid [ref: > staff.id]
  error_message text
  raw_response jsonb
  created_at timestamptz [default: `now()`]
  updated_at timestamptz [default: `now()`]
}

Table vendus_sync_log {
  id serial [pk]
  operation varchar(50) [not null]
  direction varchar(10) [not null, note: 'push, pull, both']
  entity_type varchar(50) [not null]
  entity_id varchar(100)
  vendus_id varchar(100)
  location_id uuid
  status varchar(20) [not null, note: 'started, success, error, partial']
  records_processed integer [default: 0]
  records_created integer [default: 0]
  records_updated integer [default: 0]
  records_failed integer [default: 0]
  error_message text
  error_details jsonb
  request_data jsonb
  response_data jsonb
  initiated_by uuid [ref: > staff.id]
  started_at timestamptz [default: `now()`]
  completed_at timestamptz
  duration_ms integer
}

Table vendus_retry_queue {
  id serial [pk]
  operation varchar(50) [not null]
  entity_type varchar(50) [not null]
  entity_id varchar(100) [not null]
  location_id uuid
  payload jsonb [not null]
  attempts integer [default: 0]
  max_attempts integer [default: 5]
  next_retry_at timestamptz [default: `now()`]
  last_error text
  status varchar(20) [default: 'pending', note: 'pending, processing, completed, failed, cancelled']
  created_at timestamptz [default: `now()`]
  processed_at timestamptz
}
