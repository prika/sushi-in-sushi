# =============================================================================
# SUSHI IN SUSHI - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.

# Site URL
NEXT_PUBLIC_SITE_URL=https://dominio.pt

# =============================================================================
# AUTHENTICATION
# =============================================================================
# JWT secret for API route authentication (generate: openssl rand -base64 32)
AUTH_SECRET=super-secret-key-change-me

# Session Timeout (minutes) - Automatically logs out inactive users
# Default: 30 minutes
NEXT_PUBLIC_SESSION_TIMEOUT_MINUTES=30

# =============================================================================
# ENVIRONMENT MANAGEMENT
# =============================================================================
# Controlled by npm scripts (do NOT set manually):
#   npm run dev      → NEXT_PUBLIC_APP_ENV=development (shows DEV badge)
#   npm run dev:prod → NEXT_PUBLIC_APP_ENV=production
#   npm run build    → NEXT_PUBLIC_APP_ENV=production
#   npm run start    → NEXT_PUBLIC_APP_ENV=production
#
# Single Supabase instance. Supabase Auth always used.

# =============================================================================
# PASSWORD POLICIES (Configure in Supabase Dashboard)
# =============================================================================
# Navigate to: Authentication > Policies
# Recommended settings:
#   - Minimum password length: 8 characters
#   - Require uppercase letters: Yes
#   - Require lowercase letters: Yes
#   - Require numbers: Yes
#   - Require special characters: Optional

# =============================================================================
# SUPABASE CONFIGURATION
# =============================================================================
# Get these values from your Supabase project settings:
# https://supabase.com/dashboard/project/_/settings/api

# Supabase (single instance for all environments)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# =============================================================================
# EMAIL (Resend)
# =============================================================================
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx

# Email sender (must be verified domain or onboarding@resend.dev for testing)
FROM_EMAIL=reservas@dominio.pt

# TEST MODE: When set, ALL emails are redirected to this address
# Useful for development/testing. Remove or comment out in production!
TEST_EMAIL_OVERRIDE=your-test-email@example.com

# Restaurant notification emails
RESTAURANT_EMAIL_1=reservas1@dominio.pt
RESTAURANT_EMAIL_2=reservas2@dominio.pt

# Resend Webhook Secret (for email tracking)
# Get this from: https://resend.com/webhooks
RESEND_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# =============================================================================
# CRON JOB AUTHENTICATION
# =============================================================================
# Secret token to authenticate cron job requests (Vercel Cron)
# Generate: openssl rand -hex 32
# Used by: /api/cron/reservation-reminders, /api/cron/vendus-sync
# Vercel sends as: Authorization: Bearer <CRON_SECRET>
CRON_SECRET=your_secure_random_string

# =============================================================================
# TWILIO SMS (phone verification)
# =============================================================================
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=your_twilio_phone_number_here

# =============================================================================
# VENDUS POS INTEGRATION
# =============================================================================
# Get your API key from: https://www.vendus.pt/dashboard/settings/api
# Store ID e Register ID are configured per location in admin:
#   /admin/vendus/locations
# See docs/VENDUS_SYNC.md for full setup guide
VENDUS_API_KEY=your_vendus_api_key

# Read-only mode: bloqueia todas as operacoes de escrita no Vendus (push/export).
# Util durante desenvolvimento/testes. Pull/import continuam a funcionar.
# VENDUS_READONLY=true

# =============================================================================
# ANTHROPIC API KEY
# =============================================================================
# Get your API key from: https://console.anthropic.com/api-keys
ANTHROPIC_API_KEY=your_anthropic_api_key