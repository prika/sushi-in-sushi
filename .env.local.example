# Site URL
NEXT_PUBLIC_SITE_URL=https://dominio.pt

# Authentication Configuration
# IMPORTANT: Change these values in production!
AUTH_SECRET=super-secret-key-change-me
ADMIN_PASSWORD=admin123
COZINHA_PASSWORD=123456

# Supabase Configuration
# Get these values from your Supabase project settings:
# https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Email Configuration (Resend)
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx

# Email sender (must be verified domain or onboarding@resend.dev for testing)
FROM_EMAIL=reservas@dominio.pt

# Restaurant notification emails (optional, defaults to reservas@dominio.pt)
RESTAURANT_EMAIL_1=reservas1@dominio.pt
RESTAURANT_EMAIL_2=reservas2@dominio.pt

# Resend Webhook Secret (for email tracking)
# Get this from: https://resend.com/webhooks
RESEND_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx


# =============================================
# Vendus POS Integration
# =============================================
# Get these values from your Vendus account:
# https://www.vendus.pt/dashboard/settings/api

# Global API Key (used if location-specific keys not set)
VENDUS_API_KEY=your_vendus_api_key

# Store and Register IDs
VENDUS_STORE_ID=your_store_id
VENDUS_REGISTER_ID=your_register_id

# Optional: Location-specific configuration
# Uncomment and set these if you have different API keys per location
# VENDUS_API_KEY_CIRCUNVALACAO=your_circunvalacao_api_key
# VENDUS_STORE_ID_CIRCUNVALACAO=your_circunvalacao_store_id
# VENDUS_REGISTER_ID_CIRCUNVALACAO=your_circunvalacao_register_id

# VENDUS_API_KEY_BOAVISTA=your_boavista_api_key
# VENDUS_STORE_ID_BOAVISTA=your_boavista_store_id
# VENDUS_REGISTER_ID_BOAVISTA=your_boavista_register_id

# Cron Job Secret (for automatic sync)
# Generate a secure random string for this
CRON_SECRET=your_secure_cron_secret_change_me
